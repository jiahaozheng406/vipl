# ============================================
# PRIVACY PROTECTION - EXCLUDE ALL ROOT FILES
# Only VIPL/ folder is public
# ============================================

# Exclude ALL files in root directory
/*

# Only allow these files in root
!.gitignore
!README.md
!LICENSE

# Only allow VIPL folder
!VIPL/

# ============================================
# EXCLUDE PRIVATE CONTENT
# ============================================

# Meeting materials (PRIVATE)
会议/

# Research papers (PRIVATE)
*.pdf

# Office files (PRIVATE)
*.pptx
*.ppt
*.docx
*.doc
*.xlsx
*.xls

# Any markdown files in root (PRIVATE)
/*.md
!README.md

# ============================================
# VIPL FOLDER - EXCLUDE LARGE FILES
# ============================================

# Dataset files (large files)
VIPL/datadets_cityscapes/
VIPL/datasets/
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff

# Model files (large files)
VIPL/models/
*.pth
*.pt
*.ckpt
*.pkl
*.bin
*.onnx
*.pb

# Output files
VIPL/outputs_masks/
VIPL/output/
VIPL/results/
VIPL/logs/
*.log

# ============================================
# PYTHON & DEVELOPMENT
# ============================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environment
venv/
env/
ENV/
env.bak/
venv.bak/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================
# SYSTEM FILES
# ============================================

.DS_Store
Thumbs.db
desktop.ini
*.tmp
*.temp
*.bak
*.cache

# Git
.gitattributes

# Claude
.claude/

# ============================================
# THIRD-PARTY REPOS (Use as submodules or reference)
# ============================================

# Detectron2 (external repository)
VIPL/repos/detectron2/

# Mask2Former (external repository)
VIPL/repos/Mask2Former/
